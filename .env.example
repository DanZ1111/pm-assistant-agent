# PM Product Tracker — Environment Variables
# Copy to .env locally OR set in Railway dashboard for production.
# Never commit your real .env file.

# ── Required ────────────────────────────────────────────────────────────────
# OpenAI API key for AI Intake, AI Update, and Help AI features
OPENAI_API_KEY=sk-...

# Database connection.
# Local: omit this var entirely → falls back to SQLite at ./pm_tracker.db
# Railway: attach the PostgreSQL plugin and this is auto-injected.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── First-Deploy Admin Bootstrap (DELETE after first successful login) ─────
# On startup, if no admin exists in the database AND these vars are set,
# the app will create an admin user with these credentials. Once your admin
# is created and you've logged in once, DELETE both vars from the dashboard
# so they don't sit in your environment.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# ── Optional ────────────────────────────────────────────────────────────────
# Disables uvicorn auto-reload (Railway sets RAILWAY_ENVIRONMENT automatically)
DISABLE_RELOAD=1

# ── Emergency Admin Reset (set ONLY when locked out) ──────────────────────
# When this is set, the route /auth/emergency-reset becomes accessible and
# lets anyone with this token reset the admin username + password from the
# browser. Generate a long random value (44+ chars). REMOVE this env var
# immediately after recovery — leaving it set is a permanent backdoor.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
EMERGENCY_RESET_TOKEN=
